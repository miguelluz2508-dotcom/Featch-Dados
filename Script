-- O EVENTO QUE FINALMENTE DISPARA SEU SCRIPT
SybauBtn.MouseButton1Click:Connect(function()
    local fadeInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(ScreenBlur, fadeInfo, {Size = 0}):Play()
    ScreenGui:Destroy()
    
    -- Chama a função que contém todo o seu script
    task.spawn(IniciarScriptCompleto)
end)
