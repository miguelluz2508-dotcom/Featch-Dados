-- [[ SISTEMA DE FILTRO DE PALAVRÕES ]]
local PalavrasBanidas = {
    "porra", "merda", "caralho", "foder", "foda", "vtnc", "desgraça", 
    "puta", "pqp", "arrombado", "buceta", "cu", "pica", "rola"
}

local function FiltrarTexto(texto)
    local textoFiltrado = texto
    for _, palavra in ipairs(PalavrasBanidas) do
        local padrao = palavra
        textoFiltrado = string.gsub(textoFiltrado:lower(), padrao, function(match)
            return string.rep("*", #match)
        end)
    end
    return textoFiltrado
end

