task.spawn(function()
    local assets = game:GetDescendants()
    local total = #assets
    for i = 1, total do 
        if i % 80 == 0 then 
            StatusLabel.Text = "carregando script (" .. math.floor((i/total)*100) .. ")%"
            BarFill.Size = UDim2.new(i/total, 0, 1, 0)
            task.wait() 
        end
    end
    StatusLabel.Text = "Deseja entrar no Discord?"
    BarFill.Size = UDim2.new(1, 0, 1, 0)
    task.wait(0.5)
    DiscordBtn.Visible = true
    SybauBtn.Visible = true
    BarBg.Visible = false
    TweenService:Create(SybauBtn, TweenInfo.new(0.5), {BackgroundTransparency = 0.3, TextTransparency = 0}):Play()
end)

