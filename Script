-- Funções Auxiliares de Sugestão
local function PodeEnviarSugestao()
    if isfile and isfile(CooldownFile) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(CooldownFile)) end)
        if success and data.LastDate == os.date("%x") then
            return false
        end
    end
    return true
end

local function SalvarDataEnvio()
    if writefile then
        writefile(CooldownFile, HttpService:JSONEncode({LastDate = os.date("%x")}))
    end
end

-- Função para limpar efeitos de iluminação
local function LimparShaders()
    for _, v in pairs(game.Lighting:GetChildren()) do
        if v:IsA("ColorCorrectionEffect") or v:IsA("BlurEffect") or v:IsA("BloomEffect") or v:IsA("SunRaysEffect") then
            v:Destroy()
        end
    end
end

